# Raster accuracy harness — walks BOTH pages through all 4 states.
# The cart watch()es "mismatches" + "state" (pg/out/dith/fs) under DE_TRACE;
# every analysed frame is fs=2. Verification: every fs=2 frame must report 0.
#
# Run with:
#   node tools/play.js raster_test script tools/raster_test.script \
#        --headless --trace build/raster_trace.jsonl --frames 33
#   grep '"fs=2"' build/raster_trace.jsonl   # or just: grep mismatches ...
#   # every fs=2 line should show mismatches:"0"
#
# page 1 (curved: circ/oval/rrect)
tap  2  SPACE   # f3  analyse: solid + outline
tap  6  Z       # f7  solid, no outline
tap 10  X       # f11 dither, no outline
tap 14  Z       # f15 dither + outline
# page 2 (polygons: tri/ngon/star/poly via coverage)
tap 18  C       # f19 dither + outline
tap 22  X       # f23 solid + outline
tap 26  Z       # f27 solid, no outline
tap 30  X       # f31 dither, no outline
